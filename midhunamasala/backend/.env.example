# Backend environment (Express API)
# Copy to: .env

# Server
PORT=5000
# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Supabase (service role is REQUIRED for backend; never expose to frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist (comma-separated emails)
# Used by /api/auth/sync-user to set users.role='admin'
ADMIN_EMAILS=keerthiaanand77@gmail.com

# Firebase Admin credentials (choose ONE method)
# Method A (local dev): point to your Firebase Admin SDK JSON file
# Recommended: keep this JSON OUTSIDE the repo (e.g. C:/secrets/firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Method B (production): provide individual fields instead of a JSON file
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Database migrations runner (optional but recommended)
# Supabase Postgres connection string (Settings → Database → Connection string)
DATABASE_URL=
# If true, pg will use SSL with rejectUnauthorized=false (recommended for Supabase)
DATABASE_SSL=true
